# ──────────────────────────────────────────────────────────────────────────────
# Python
# ──────────────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
eggs/
*.egg
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ──────────────────────────────────────────────────────────────────────────────
# Virtual environments
# ──────────────────────────────────────────────────────────────────────────────
venv/
env/
.venv/
.env
*.env

# ──────────────────────────────────────────────────────────────────────────────
# IDE / editors
# ──────────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.orig
*.bak

# ──────────────────────────────────────────────────────────────────────────────
# Jupyter
# ──────────────────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ──────────────────────────────────────────────────────────────────────────────
# OS
# ──────────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ──────────────────────────────────────────────────────────────────────────────
# Large raw data (DFSAR mosaics, LOLA DEMs — never commit binary science data)
# ──────────────────────────────────────────────────────────────────────────────
data/raw/**
!data/raw/lola_dem/*.lbl.txt
!data/raw/lola_dem/*.lbl
!data/raw/.gitkeep

data/processed/**
!data/processed/.gitkeep

data/external/**
!data/external/.gitkeep

# ──────────────────────────────────────────────────────────────────────────────
# Large numpy prediction caches (600 MB each)
# ──────────────────────────────────────────────────────────────────────────────
outputs/*.npy
outputs/west/*.npy

# ──────────────────────────────────────────────────────────────────────────────
# Model checkpoints (multi-hundred MB — share via HuggingFace / Drive)
# ──────────────────────────────────────────────────────────────────────────────
checkpoints/*.pth
checkpoints/*.pt
checkpoints/west/
*.onnx
*.h5
*.safetensors

# Keep training history (small JSON)
!checkpoints/training_history.json

# ──────────────────────────────────────────────────────────────────────────────
# Logs / experiment tracking
# ──────────────────────────────────────────────────────────────────────────────
logs/
*.log
wandb/
mlruns/
lightning_logs/
runs/

# ──────────────────────────────────────────────────────────────────────────────
# Secrets / credentials
# ──────────────────────────────────────────────────────────────────────────────
.env
*.key
credentials/
secrets/
*.pem
*.p12

# ──────────────────────────────────────────────────────────────────────────────
# Claude Code internal files
# ──────────────────────────────────────────────────────────────────────────────
.claude/

# ──────────────────────────────────────────────────────────────────────────────
# Temp / scratch
# ──────────────────────────────────────────────────────────────────────────────
tmp/
temp/
scratch/
*.tmp
*.temp
